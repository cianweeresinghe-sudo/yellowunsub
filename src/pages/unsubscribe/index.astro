---
import Layout from '../../components/Layout.astro';
import { brands } from '../../data/brands';

const title = 'Unsubscribe guides';
const description = 'Browse unsubscribe guides by brand.';
---

<Layout title={title} description={description}>
  <section class="hero">
    <div class="container">
      <h1>Unsubscribe guides</h1>
      <p>Pick a brand. Get the fastest steps + official links.</p>
    </div>
  </section>

  <section class="container" style="padding: 0 0 2.2rem;">
    <div class="card">
      <div class="pad">
        <div class="links">
          {brands
            .slice()
            .sort((a, b) => a.name.localeCompare(b.name))
            .map((b) => (
              <a class="link" href={Astro.base + `/unsubscribe/${b.slug}/`}>
                <strong>{b.name}</strong>
                <span>{b.category} · {b.summary}</span>
              </a>
            ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
