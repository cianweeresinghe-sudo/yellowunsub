---
import Layout from '../components/Layout.astro';
import { brands, categories } from '../data/brands';
import { siteConfig } from '../config';

const title = 'Unsubscribe without the rage';
const description = 'UK-focused unsubscribe guides: official links, quick steps, and alternatives.';
---

<Layout title={title} description={description}>
  <section class="hero">
    <div class="container">
      <h1>Unsubscribe without the rage.</h1>
      <p>
        {siteConfig.name} is a UK-focused directory of unsubscribe guides — one page per brand, with the
        official links and the fastest steps.
      </p>

      <div class="pills">
        <span class="pill">Email only (for now)</span>
        <span class="pill">UK first</span>
        <span class="pill">No login required</span>
      </div>

      <div style="margin-top: 1.25rem; display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <a class="pill" href={Astro.base + '/unsubscribe/'} style="color: var(--text); border-color: rgba(250,204,21,0.45);">
          Browse brands ({brands.length})
        </a>
        <a class="pill" href={Astro.base + '/unsubscribe/guides/gmail/'}>
          Gmail guide
        </a>
      </div>
    </div>
  </section>

  <section class="container" style="padding: 0 0 2.2rem;">
    <div class="grid">
      <div class="card">
        <div class="pad">
          <div class="kicker">Start here</div>
          <h2>Newest guides</h2>
          <div class="links">
            {brands.slice(0, 6).map((b) => (
              <a class="link" href={Astro.base + `/unsubscribe/${b.slug}/`}>
                <strong>How to unsubscribe from {b.name} emails</strong>
                <span>{b.category} · {b.summary}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="card">
        <div class="pad">
          <div class="kicker">Browse by category</div>
          <h2>Categories</h2>
          <div class="links">
            {categories.map((c) => (
              <a class="link" href={Astro.base + `/unsubscribe/category/${encodeURIComponent(c)}/`}>
                <strong>{c}</strong>
                <span>{brands.filter((b) => b.category === c).length} brand(s)</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
